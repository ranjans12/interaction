<script>
  function navigateTo(pageId) {
    const pages = document.querySelectorAll('.page');
    pages.forEach(p => p.classList.remove('active'));
    document.getElementById(pageId).classList.add('active');
  }

  // Passcode Engine
  const SECRET_CODE = "2008"; let currentInput = ""; const displayEl = document.getElementById("passcodeDisplay");
  function pressNum(num) { if (currentInput.length < 4) { currentInput += num; updateDisplay(); } }
  function clearPass() { currentInput = ""; updateDisplay(); }
  function updateDisplay() { displayEl.textContent = "💝".repeat(currentInput.length); }
  function checkPass() { if (currentInput === SECRET_CODE) { navigateTo("page2"); } else { displayEl.style.borderColor = "#ffccd5"; alert("Wrong password! Think of our special date 😉😏"); clearPass(); } }

  // Trivia Array Deck Configuration
  const triviaData = [
    { lyric: '"there\'s things "Violet Blue Green Red to keep me at arm\'s length don\'t work, I win"', options: ["West coast", "Video games", "Cinnamon girl", "Born to Die"], correct: "Cinnamon girl", poster: "1.jpg", compliment: "You are my Cinnamon girl my Sahiba cute gentle and always lovable 💖", hint: "Hint: dal chini ladki😏" },
    { lyric: '"Do you think we\'ll be in love forever, Do you think we"ll be in love?"', options: ["Born to Die", "Salvatore", "diet mountain dew", "Love Song"], correct: "diet mountain dew", poster: "2.jpg", compliment: "So do you think??😏😏 You are going amazing this proves you are a top Lana Del Ray fan ✨", hint: "Hint: Diet Mountain Dew, Baby, New York City" },
    { lyric: '"You come back, I\'ll be right here Like a barge at sea In the storm, I stay clear \'cause I got my mind on you"', options: ["Young and Beautiful", "Say Yes To Heaven", "Brooklyn Baby", "West coast"], correct: "Say Yes To Heaven", poster: "3.jpg", compliment: "ahaaa good going tooo made it right too ig ur good at this game 💕", hint: "Hint: merko har chiz pr jo bolti uska ulta heaven ko bolo🤣🤣🤣🤣" },
    { lyric: '"I\'ve got feathers in my hair, I get fown to beat poetry, And my jazz collection\'s rare i can play most anything"', options: ["Chemtrails Over the country Club", "Brooklyn Baby", "Abyss", "cinnamon girl"], correct: "Brooklyn Baby", poster: "4.jpg", compliment: "GREAT!! you know another great song of her Abyss whos lines goes like \"you know my heart belongs to you one last time say that you want me tooooo\" 🎶", hint: "Hint: Maybe your fav one or the one in ur insta profile" }
  ];

  let currentIndex = 0, totalHearts = 3, questionLocked = false, crackerInterval;
  function shuffleArray(array) { for (let i = array.length - 1; i > 0; i--) { const j = Math.floor(Math.random() * (i + 1)); [array[i], array[j]] = [array[j], array[i]]; } }
  function initGame() { currentIndex = 0; totalHearts = 3; questionLocked = false; shuffleArray(triviaData); updateHearts(); loadQuestion(); }
  function updateHearts() { document.getElementById("heartsContainer").textContent = "❤️".repeat(totalHearts); }

  function loadQuestion() {
    questionLocked = false; document.getElementById("feedbackDisplay").innerHTML = "";
    const currentData = triviaData[currentIndex];
    document.getElementById("questionDisplay").textContent = currentData.lyric;
    document.getElementById("posterDisplay").src = currentData.poster;
    const optionsGrid = document.getElementById("optionsContainer"); optionsGrid.innerHTML = "";
    currentData.options.forEach(opt => {
      const btn = document.createElement("div"); btn.className = "glass-box option-box"; btn.textContent = opt;
      btn.onclick = () => handleAnswer(opt, btn); optionsGrid.appendChild(btn);
    });
  }

  function burstCrackers() {
    const emojis = ["🎉", "✨", "💥", "🥳", "💖"]; const end = Date.now() + 2000;
    crackerInterval = setInterval(() => {
      if (Date.now() > end) { clearInterval(crackerInterval); return; }
      for (let i = 0; i < 5; i++) {
        const c = document.createElement("div"); c.className = "cracker"; c.textContent = emojis[Math.floor(Math.random() * emojis.length)];
        c.style.left = Math.random() * 100 + "vw"; c.style.top = Math.random() * 100 + "vh";
        c.style.setProperty('--mx', (Math.random() * 200 - 100) + 'px'); c.style.setProperty('--my', (Math.random() * 200 - 100) + 'px');
        document.body.appendChild(c); setTimeout(() => c.remove(), 2000);
      }
    }, 150);
  }

  function handleAnswer(selectedOption, elementClicked) {
    if (questionLocked) return;
    const currentData = triviaData[currentIndex]; const feedbackBox = document.getElementById("feedbackDisplay");
    if (selectedOption === currentData.correct) {
      questionLocked = true; burstCrackers(); 
      const isLast = (currentIndex === triviaData.length - 1);
      const buttonLabel = isLast ? "Go to the surprise!! 🎁💝" : "Next Question ➡️";
      feedbackBox.innerHTML = `<div class="glass-box compliment-box"><h3>Correct! 🎉</h3><p>${currentData.compliment}</p><button class="next-btn" onclick="nextStep()">${buttonLabel}</button></div>`;
    } else {
      totalHearts--; updateHearts();
      if (totalHearts <= 0) { alert("Oh no! You ran out of hearts! Let's restart the game sweetie... 🌸"); initGame(); } 
      else { feedbackBox.innerHTML = `<div class="hint-text">${currentData.hint}</div>`; }
    }
  }
  function nextStep() { clearInterval(crackerInterval); currentIndex++; if (currentIndex < triviaData.length) { loadQuestion(); } else { navigateTo("page4"); } }

  // Bouquet Engine Logic
  const flowerFortunes = {
    rose: "Fortune: You're incredibly smart and capture my mind entirely.🌹 and i really know u gonna chose those lilies and tulips my cute butterfly🦋",
    tulip: "Fortune: You have the most genuine, elegant laugh that cures everything. 🌷",
    daisy: "Fortune: Your energy is pure sunshine; you brighten up my dullest days. 🌼",
    lily: "Fortune: You are deeply thoughtful and uniquely lovable in every single aspect. 💮",
    sunflower: "Fortune: I choose you completely, and looking at you makes 'forever' sound beautiful. 🌻",
    lavender: "Fortune: Your presence is so calming and peaceful, just like a field of lavender. You make my entire world serene. 🪻"
  };
  let totalFlowersAdded = 0; const REQUIRED_FLOWERS = 6;
  function addFlowerToVase(type, emojiSymbol) {
    totalFlowersAdded++; burstCrackers(); const canvas = document.getElementById("vaseCanvas"); const emojiElement = document.createElement("div");
    emojiElement.className = "placed-flower-emoji"; emojiElement.textContent = emojiSymbol;
    const randomLeft = Math.floor(Math.random() * 100) + 110; const randomTop = Math.floor(Math.random() * 90) + 120; const randomRotation = Math.floor(Math.random() * 60) - 30;
    emojiElement.style.left = `${randomLeft}px`; emojiElement.style.top = `${randomTop}px`; emojiElement.style.setProperty('--rot', `${randomRotation}deg`); canvas.appendChild(emojiElement);
    const fortuneBox = document.getElementById("fortuneDisplay"); let labelText = `🌸 Note #${totalFlowersAdded} opened!`;
    if (totalFlowersAdded === 2) { labelText = "ik u very well coz remembering is my love language"; }
    fortuneBox.innerHTML = `<div><span class="fortune-highlight">${labelText}</span><span>"${flowerFortunes[type]}"</span></div>`;
    if (totalFlowersAdded >= REQUIRED_FLOWERS) { document.getElementById("deliveryContainer").style.display = "block"; }
  }

  // Playlist Engine
  let songsReadState = { 1: false, 2: false, 3: false, 4: false, 5: false };
  function openPlaylistDeck() { document.getElementById("musicGate").style.display = "none"; document.getElementById("playlistDeck").style.display = "flex"; }
  function openDedication(id) { document.getElementById("playlistDeck").style.display = "none"; document.getElementById(`dedication${id}`).style.display = "block"; songsReadState[id] = true; }
  function closeDedication(id) { document.getElementById(`dedication${id}`).style.display = "none"; document.getElementById("playlistDeck").style.display = "flex"; checkPlaylistCompletion(); }
  function checkPlaylistCompletion() { if (songsReadState[1] && songsReadState[2] && songsReadState[3] && songsReadState[4] && songsReadState[5]) { document.getElementById("finalSurpriseTriggerBox").style.display = "block"; } }

  // Interactive Mailbox Actions
  function unsealEnvelope() {
    burstCrackers();
    setTimeout(() => {
      navigateTo('page7');
    }, 1200);
  }
</script>
